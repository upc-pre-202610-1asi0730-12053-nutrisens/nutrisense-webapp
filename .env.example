# Base URL for the NutriSense Platform API (include /api/v1 suffix)
VITE_API_BASE_URL=http://localhost:5000/api/v1

# Stripe publishable key — use pk_test_... for development, pk_live_... for production
# Never put the secret key (sk_...) here; it must stay server-side only.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
